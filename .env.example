# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/repo_sync?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# GitHub App
GITHUB_APP_ID=""
GITHUB_APP_SLUG=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""

# GitHub OAuth (for user login)
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
GITHUB_OAUTH_CALLBACK_URL="http://localhost:3001/auth/github/callback"

# Server
API_PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:5173"

# Encryption key for storing GitHub tokens
ENCRYPTION_KEY="change-me-32-byte-hex-key-here!!"
